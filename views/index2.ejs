}
.testimonial-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.1); }
.testimonial-card::before {
  content: '"';
  position: absolute;
  top: 20px; right: 28px;
  font-family: 'Playfair Display', serif;
  font-size: 80px;
  color: rgba(255,107,53,0.08);
  line-height: 1;
  font-weight: 900;
}
.test-stars { color: var(--gold); font-size: 14px; letter-spacing: 2px; margin-bottom: 18px; }
.test-text { font-size: 15px; color: var(--text-mid); line-height: 1.75; margin-bottom: 24px; font-style: italic; }
.test-author { display: flex; align-items: center; gap: 14px; }
.test-avatar {

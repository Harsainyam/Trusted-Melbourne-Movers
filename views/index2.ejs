/* ─── PROCESS ─── */
.process-section { background: var(--cream); padding: 100px 0; }
.process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(0,0,0,0.06); border-radius: 20px; overflow: hidden; margin-top: 60px; }
.process-step {

 }

 .services-grid {
     display: flex;
     justify-content: center;
     flex-wrap: wrap;
     grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
     gap: 40px;
     justify-items: center;
 }


 .service-card {

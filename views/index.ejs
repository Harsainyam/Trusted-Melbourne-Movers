 }

 .main-con {
     display: flex;
     justify-content: center;
     flex-wrap: wrap;
 }

 .content-section2 {
     display: flex;
     justify-content: center;
     flex-wrap: wrap;
     background-color: #e2ebf0
 }

 .content1 {
     width: 50em;
